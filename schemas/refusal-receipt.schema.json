{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "receipt_chain_core.refusal_receipt.v0.1",
  "title": "Refusal Receipt",
  "description": "A typed projection of a refusal-class ChainedReceipt. Proves that a refusal happened, has a typed structure, is hash-bound, and can be validated. Does not prove cryptographic signature, legal admissibility, or production readiness.",
  "type": "object",
  "required": [
    "schema",
    "receipt_type",
    "decision_id",
    "issued_at",
    "prior_chain_state_hash",
    "proposed_action",
    "verdict",
    "reason_code",
    "reason",
    "receipt_hash",
    "does_not_execute",
    "does_not_bind_consequence"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "const": "receipt_chain_core.refusal_receipt.v0.1"
    },
    "receipt_type": {
      "type": "string",
      "const": "refusal_receipt"
    },
    "decision_id": {
      "type": "string",
      "minLength": 1
    },
    "issued_at": {
      "type": "string",
      "minLength": 1
    },
    "prior_chain_state_hash": {
      "oneOf": [
        {"type": "null"},
        {"type": "string", "minLength": 1}
      ]
    },
    "proposed_action": {
      "type": "object",
      "required": ["action_type", "object_id"],
      "properties": {
        "action_type": {"type": "string", "minLength": 1},
        "object_id": {"type": "string", "minLength": 1}
      }
    },
    "verdict": {
      "type": "string",
      "enum": ["DENY", "HOLD", "REBIND_REQUIRED"]
    },
    "reason_code": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string"
    },
    "receipt_hash": {
      "type": "string",
      "minLength": 1
    },
    "does_not_execute": {
      "type": "boolean",
      "const": true
    },
    "does_not_bind_consequence": {
      "type": "boolean",
      "const": true
    }
  },
  "additionalProperties": false
}
